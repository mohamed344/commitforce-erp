# Copy this file to .env.local and fill in the values.
# .env.local is gitignored. All NEXT_PUBLIC_* vars are exposed to the browser.

# ─────────────────────────────────────────────────────────────
# Supabase credentials (Project Settings > API)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# New-style publishable key (sb_publishable_...) — the anon-equivalent.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxx

# Server-only secret — never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─────────────────────────────────────────────────────────────
# App / branding
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=IMAB ERP
NEXT_PUBLIC_APP_VERSION=0.1.0

NEXT_PUBLIC_ENTERPRISE_NAME=IMAB Engineering
NEXT_PUBLIC_ENTERPRISE_SHORT=IM
NEXT_PUBLIC_ENTERPRISE_EMAIL=admin@imab-engineering.dz
# Optional logo image URL; leave empty to use the monogram gradient.
NEXT_PUBLIC_LOGO_URL=

# Theme (hex colors — must be quoted; a leading # is otherwise a comment)
NEXT_PUBLIC_BRAND_COLOR="#16a34a"
NEXT_PUBLIC_BRAND_COLOR_DARK="#0f7235"
NEXT_PUBLIC_FONT_FAMILY=Inter

# Languages (comma-separated; first/default is NEXT_PUBLIC_DEFAULT_LOCALE)
NEXT_PUBLIC_DEFAULT_LOCALE=fr
NEXT_PUBLIC_LOCALES=fr,en,ar

# ─────────────────────────────────────────────────────────────
# Modules — set to true to enable a module tile (default: false)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_MODULE_STOCK=false
NEXT_PUBLIC_MODULE_SALES=false
NEXT_PUBLIC_MODULE_CRM=false
NEXT_PUBLIC_MODULE_PRODUCTION=false
NEXT_PUBLIC_MODULE_PROJECTS=false
NEXT_PUBLIC_MODULE_HR=false
NEXT_PUBLIC_MODULE_REPORTS=false
NEXT_PUBLIC_MODULE_SETTINGS=false
